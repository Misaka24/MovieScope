NODE_ENV=production
WEB_IMAGE=ghcr.io/YOUR_GITHUB_OWNER/moviescope-web:latest
API_IMAGE=ghcr.io/YOUR_GITHUB_OWNER/moviescope-api:latest
API_HOST=0.0.0.0
API_PORT=8787
WEB_ORIGIN=https://moviescope.example.com

MYSQL_DATABASE=moviescope
MYSQL_USER=moviescope_app
MYSQL_PASSWORD=CHANGE_TO_A_LONG_RANDOM_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_TO_ANOTHER_LONG_RANDOM_PASSWORD
MYSQL_CONNECTION_LIMIT=10

TMDB_ACCESS_TOKEN=
JUSTONE_API_TOKEN=

# 第三方接口故障时尽快回退 SQL 旧缓存；优先 IPv4 避免无 IPv6 路由时等待。
API_TIMEOUT_MS=8000
NODE_OPTIONS=--dns-result-order=ipv4first
