{
  "name": "moviescope-frontend-drafts",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "vite --host 127.0.0.1",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "vue-tsc -b",
    "test": "node --test server/*.test.mjs",
    "check": "npm run typecheck && npm test && npm run build",
    "api": "node server/server.mjs",
    "dev:all": "node scripts/dev.mjs",
    "cache:inspect": "node scripts/inspect-cache.mjs",
    "cache:export": "node scripts/export-cache.mjs",
    "admin:promote": "node scripts/promote-admin.mjs",
    "data:seed-realistic": "node scripts/seed-realistic-data.mjs"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.6",
    "@fontsource/jetbrains-mono": "^5.2.6",
    "material-symbols": "^0.40.2",
    "mysql2": "^3.14.5",
    "vue": "3.5.39",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.10",
    "@types/node": "24.10.1",
    "@vitejs/plugin-vue": "6.0.7",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "5.9.3",
    "vite": "8.1.4",
    "vue-tsc": "3.3.7"
  }
}
